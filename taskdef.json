{
  "family": "task-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::148908330752:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "task-api",
      "image": "148908330752.dkr.ecr.eu-north-1.amazonaws.com/task-api:IMAGE_TAG",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:148908330752:secret:task-api-db-YdOn98:DB_HOST::"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:148908330752:secret:task-api-db-YdOn98:DB_PORT::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:148908330752:secret:task-api-db-YdOn98:DB_USER::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:148908330752:secret:task-api-db-YdOn98:DB_PASSWORD::"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:148908330752:secret:task-api-db-YdOn98:DB_NAME::"
        }
      ]
    }
  ]
}